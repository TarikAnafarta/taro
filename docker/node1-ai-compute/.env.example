# ============================================================
# Taro — Node 1 (AI Compute) Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.
# ============================================================

# --- Node Addresses ---
# LAN IP of this machine (AI Compute node)
NODE1_HOST=192.168.1.100
# LAN IP of the Core Services node
NODE2_HOST=192.168.1.101

# --- AI Gateway ---
AI_GATEWAY_HOST=0.0.0.0
AI_GATEWAY_PORT=8100

# --- Ollama ---
OLLAMA_HOST=0.0.0.0
# Models are configurable — change these to use different models
TARO_CHAT_MODEL=qwen2.5:7b
TARO_EMBEDDING_MODEL=nomic-embed-text

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# --- NATS (connects to Node 2's NATS server) ---
NATS_URL=nats://${NODE2_HOST}:4222

# --- Logging ---
LOG_LEVEL=info
LOG_FORMAT=json
