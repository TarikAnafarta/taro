# ============================================================
# Taro — Node 2 (Core Services) Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.
# ============================================================

# --- Node Addresses ---
# LAN IP of the AI Compute node
NODE1_HOST=192.168.1.100
# LAN IP of this machine (Core Services node)
NODE2_HOST=192.168.1.101

# --- Service URLs (derived from node hosts) ---
NODE1_AI_GATEWAY_URL=http://${NODE1_HOST}:8100
NODE1_OLLAMA_URL=http://${NODE1_HOST}:11434
NODE1_QDRANT_URL=http://${NODE1_HOST}:6333
NODE2_API_URL=http://${NODE2_HOST}:8000
NODE2_DASHBOARD_URL=http://${NODE2_HOST}:3000

# --- Taro API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Dashboard ---
NEXT_PUBLIC_API_URL=http://${NODE2_HOST}:8000

# --- PostgreSQL ---
POSTGRES_USER=taro
POSTGRES_PASSWORD=taro_secret_change_me
POSTGRES_DB=taro
POSTGRES_PORT=5432
POSTGRES_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://redis:${REDIS_PORT}/0

# --- NATS ---
NATS_PORT=4222
NATS_MONITOR_PORT=8222
NATS_WEBSOCKET_PORT=8443
NATS_URL=nats://nats:${NATS_PORT}

# --- MinIO ---
MINIO_ROOT_USER=taro
MINIO_ROOT_PASSWORD=taro_minio_secret_change_me
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- AI Models (must match Node 1) ---
TARO_CHAT_MODEL=qwen2.5:7b
TARO_EMBEDDING_MODEL=nomic-embed-text

# --- Authentication ---
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHARACTER_STRING
JWT_EXPIRY_MINUTES=60

# --- Logging ---
LOG_LEVEL=info
LOG_FORMAT=json

# --- Monitoring ---
BESZEL_PORT=8090
UPTIME_KUMA_PORT=3001
